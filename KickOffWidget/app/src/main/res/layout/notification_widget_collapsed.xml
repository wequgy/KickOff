<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="64dp"
    android:background="@android:color/transparent"
    android:padding="0dp">

    <!-- Background Image with negative margins to clip rounded corners -->
    <ImageView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginStart="-12dp"
        android:layout_marginTop="-12dp"
        android:layout_marginEnd="-12dp"
        android:layout_marginBottom="-12dp"
        android:src="@drawable/widget_card_background"
        android:scaleType="centerCrop" />

    <!-- Dim Overlay -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/widget_background_dim" />

    <!-- Main Content Area -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp">

        <!-- Home Team -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <FrameLayout
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:background="@drawable/widget_flag_container">

                <ImageView
                    android:id="@+id/home_logo"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:layout_marginStart="1.5dp"
                    android:layout_marginTop="1.5dp"
                    android:layout_marginEnd="4dp"
                    android:layout_marginBottom="4dp"
                    android:scaleType="fitCenter" />
            </FrameLayout>

            <TextView
                android:id="@+id/home_code"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="6dp"
                android:textColor="@color/on_primary"
                android:textStyle="bold"
                android:textSize="14sp" />
        </LinearLayout>

        <!-- Spacer -->
        <FrameLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1" />

        <!-- Center Section (Countdown Pill) -->
        <ImageView
            android:id="@+id/countdown_pill"
            android:layout_width="94dp"
            android:layout_height="38dp"
            android:scaleType="fitCenter" />

        <!-- Spacer -->
        <FrameLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1" />

        <!-- Away Team -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/away_code"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="6dp"
                android:textColor="@color/on_primary"
                android:textStyle="bold"
                android:textSize="14sp" />

            <FrameLayout
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:background="@drawable/widget_flag_container">

                <ImageView
                    android:id="@+id/away_logo"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:layout_marginStart="1.5dp"
                    android:layout_marginTop="1.5dp"
                    android:layout_marginEnd="4dp"
                    android:layout_marginBottom="4dp"
                    android:scaleType="fitCenter" />
            </FrameLayout>
        </LinearLayout>
    </LinearLayout>
</RelativeLayout>
