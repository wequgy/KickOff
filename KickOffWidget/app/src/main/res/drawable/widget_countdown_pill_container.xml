<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Back layer: Shadow -->
    <item
        android:left="4dp"
        android:top="4dp">
        <shape android:shape="rectangle">
            <solid android:color="@color/on_primary_fixed" />
            <corners android:radius="10dp" />
        </shape>
    </item>

    <!-- Front layer: Border + Background -->
    <item
        android:right="4dp"
        android:bottom="4dp">
        <shape android:shape="rectangle">
            <solid android:color="@color/surface_container_low" />
            <stroke
                android:width="2dp"
                android:color="@color/primary_fixed_dim" />
            <corners android:radius="10dp" />
        </shape>
    </item>
</layer-list>
